{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/search",
      "dest": "/api/search.js"
    },
    {
      "src": "/api/photos/(.*)",
      "dest": "/api/photos/[filename].js"
    },
    {
      "src": "/",
      "dest": "/api/index.js"
    }
  ]
}
